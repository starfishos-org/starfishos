+def vm_disk_copy_is_complete(drive: str, per_vm_drive: str):
+    """Reject unsafe or legacy/interrupted final-name disk copies."""
+    try:
+        source = os.stat(drive)
+        destination = os.stat(per_vm_drive, follow_symlinks=False)
+        return (stat.S_ISREG(source.st_mode)
+                and stat.S_ISREG(destination.st_mode)
+                and destination.st_size == source.st_size
+                and (destination.st_dev, destination.st_ino)
+                    != (source.st_dev, source.st_ino))
+    except OSError:
+        return False
+
+
+def remove_vm_disk_copy(path: str):
+    try:
+        os.unlink(path)
+    except FileNotFoundError:
+        pass
+
+
+def prepare_vm_disk_copy(drive: str, per_vm_drive: str):
+    """Return an atomic sparse-copy job after removing stale output."""
+    partial_drive = f'{per_vm_drive}.partial'
+    source_absolute = os.path.abspath(drive)
+    source_real = os.path.realpath(drive)
+    for output in (per_vm_drive, partial_drive):
+        if (source_absolute == os.path.abspath(output)
+                or (source_real == os.path.realpath(output)
+                    and not os.path.islink(output))):
+            raise ValueError('VM disk outputs must differ from the base image')
+    remove_vm_disk_copy(per_vm_drive)
+    remove_vm_disk_copy(partial_drive)
+    cmd = ['cp', '--sparse=always', '--reflink=auto', '--',
+           drive, partial_drive]
+    return cmd, partial_drive
+
+
+def publish_vm_disk_copy(drive: str, partial_drive: str, per_vm_drive: str):
+    if not vm_disk_copy_is_complete(drive, partial_drive):
+        raise RuntimeError(f'incomplete VM disk copy: {partial_drive}')
+    os.replace(partial_drive, per_vm_drive)
+
+
+def copy_one_vm_disk(drive: str, per_vm_drive: str):
+    if vm_disk_copy_is_complete(drive, per_vm_drive):
+        return
+    cmd, partial_drive = prepare_vm_disk_copy(drive, per_vm_drive)
+    try:
+        run_local_command(cmd)
+        publish_vm_disk_copy(drive, partial_drive, per_vm_drive)
+    except BaseException:
+        remove_vm_disk_copy(partial_drive)
+        raise
+
+
