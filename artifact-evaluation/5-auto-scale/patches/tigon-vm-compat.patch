+            running_procs.append((p, cmd))
+        pending = set(range(len(running_procs)))
+        while pending:
+            for index in tuple(pending):
+                p, cmd = running_procs[index]
+                returncode = p.poll()
+                if returncode is None:
+                    continue
+                pending.remove(index)
+                outs, errs = p.communicate()
