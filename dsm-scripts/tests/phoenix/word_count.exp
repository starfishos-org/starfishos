#!/usr/bin/expect  

set timeout 120
set thread_num [lindex $argv 0]
if { $thread_num == "" } {
    set thread_num 16
}
# start
spawn ./build/simulate.sh
expect "Welcome to ChCore shell!"
# run anything you like here
# interact
send -- "word_count.bin -f word_50MB.txt -t $thread_num -n 10 & \r"
expect "done"
exit
