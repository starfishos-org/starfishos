#!/usr/bin/expect  

set timeout 120
set thread_num [lindex $argv 0]

if { $thread_num == "" } {
    set thread_num 1
}

# start
spawn ./build/simulate.sh
expect "Welcome to ChCore shell!"
# run anything you like here
# interact
send -- "matrix_multiply.bin -l 1000 -r 1000 -t $thread_num -c 0 \n"
expect "done"
exit
