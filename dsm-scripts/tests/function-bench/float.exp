#!/usr/bin/expect  

set timeout 120
set N [lindex $argv 0]

if { $N == "" } {
    set N 10000000
}

# start
spawn ./build/simulate.sh
expect "Welcome to ChCore shell!"
# run anything you like here
# interact
send -- "test_float.bin $N 0\n"
expect "done"
sleep 1
send -- "test_float.bin $N 1 \n"
expect "done"
sleep 1
send -- "test_float.bin $N 2 \n"
expect "done"
sleep 1
exit
