	branch = master
[submodule "test-on-linux/leveldb"]
	path = test-on-linux/leveldb
	url = https://github.com/starfishos-org/leveldb.git
	branch = dev
[submodule "test-on-linux/linux-kernel-test"]
	path = test-on-linux/linux-kernel-test
