# Linux baselines for paper Ideal / Distributed curves (AE auto-scale, etc.)
[submodule "test-on-linux/phoenix"]
	path = test-on-linux/phoenix
	url = https://github.com/starfishos-org/phoenix.git
	branch = cmake-debug
[submodule "test-on-linux/dbx1000"]
	path = test-on-linux/dbx1000
	url = https://github.com/starfishos-org/dbx1000.git
	branch = master
[submodule "test-on-linux/GeminiGraph"]
	path = test-on-linux/GeminiGraph
